# Copy to .dev.vars (gitignored) for local `npm run dev`
# Production Pages secrets: Cloudflare dashboard → tryon-rvw → Settings → Variables

LITELLM_BASE_URL=https://litellm.irltechnology.com
LITELLM_API_KEY=sk-your-key

# Default when no model is sent in the form
LITELLM_MODEL=gpt-image-1

# Per UI model selector (must match names configured in your LiteLLM proxy)
LITELLM_MODEL_GPT_IMAGE=gpt-image-1
LITELLM_MODEL_DALLE3=dall-e-3

# Optional — require Authorization: Bearer <BG_REMOVE_SECRET>
BG_REMOVE_SECRET=
